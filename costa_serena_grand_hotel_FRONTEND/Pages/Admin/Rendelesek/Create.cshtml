@page
@model costa_serena_grand_hotel_FRONTEND.Pages.Admin.Rendelesek.CreateModel
@{
    ViewData["Title"] = "Új rendelés";
    ViewData["AdminTitle"] = "Új rendelés";
    ViewData["AdminSubTitle"] = "Új rendelés létrehozása.";
    ViewData["AdminBackPage"] = "/Admin/Rendelesek/Index";
}

<section class="section-soft admin-page-section">
    <div class="container admin-crud-container">
        <partial name="_AdminCrudHeader" />

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">@Model.ErrorMessage</div>
        }

        <div class="admin-crud-card">
            <form method="post">
                <div class="admin-form-grid">
                    <div class="admin-col-6">
                        <label asp-for="Rendeles.VendegId" class="form-label">Vendég</label>
                        <select asp-for="Rendeles.VendegId" id="vendegSelect" class="form-select form-soft rounded-4">
                            <option value="">-- Válassz vendéget --</option>
                            @foreach (var item in Model.Vendegek)
                            {
                                <option value="@item.Id"
                                        data-nev="@item.Nev"
                                        data-szemelyi="@item.SzemelyiIgazolvanySzam"
                                        data-iranyitoszam="@item.IranyitoSzam"
                                        data-varos="@item.Varos"
                                        data-utca="@item.Utca"
                                        data-hazszam="@item.Hazszam">
                                    @item.Id - @item.Nev
                                </option>
                            }
                        </select>
                    </div>

                    <div class="admin-col-6">
                        <label asp-for="Rendeles.Nev" class="form-label">Név</label>
                        <input asp-for="Rendeles.Nev" id="rendelesNev" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-6">
                        <label asp-for="Rendeles.SzemelyiIgazolvanySzam" class="form-label">Személyi igazolvány szám</label>
                        <input asp-for="Rendeles.SzemelyiIgazolvanySzam" id="rendelesSzemelyi" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-3">
                        <label asp-for="Rendeles.IranyitoSzam" class="form-label">Irányítószám</label>
                        <input asp-for="Rendeles.IranyitoSzam" id="rendelesIranyitoszam" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-3">
                        <label asp-for="Rendeles.Hazszam" class="form-label">Házszám</label>
                        <input asp-for="Rendeles.Hazszam" id="rendelesHazszam" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-6">
                        <label asp-for="Rendeles.Varos" class="form-label">Város</label>
                        <input asp-for="Rendeles.Varos" id="rendelesVaros" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-6">
                        <label asp-for="Rendeles.Utca" class="form-label">Utca</label>
                        <input asp-for="Rendeles.Utca" id="rendelesUtca" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-4">
                        <label asp-for="Rendeles.Vegosszeg" class="form-label">Végösszeg</label>
                        <input asp-for="Rendeles.Vegosszeg" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-4">
                        <div class="form-check mt-4">
                            <input asp-for="Rendeles.Fizetett" class="form-check-input" />
                            <label asp-for="Rendeles.Fizetett" class="form-check-label">Fizetett</label>
                        </div>
                    </div>

                    <div class="admin-col-4">
                        <div class="form-check mt-4">
                            <input asp-for="Rendeles.Elkuldve" class="form-check-input" />
                            <label asp-for="Rendeles.Elkuldve" class="form-check-label">Elküldött</label>
                        </div>
                    </div>
                </div>

                <div class="admin-form-actions">
                    <button type="submit" class="btn btn-success rounded-pill px-4">Mentés</button>
                    <a asp-page="/Admin/Rendelesek/Index" class="btn btn-outline-secondary rounded-pill px-4">Mégse</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const select = document.getElementById('vendegSelect');
            const nev = document.getElementById('rendelesNev');
            const szemelyi = document.getElementById('rendelesSzemelyi');
            const iranyitoszam = document.getElementById('rendelesIranyitoszam');
            const varos = document.getElementById('rendelesVaros');
            const utca = document.getElementById('rendelesUtca');
            const hazszam = document.getElementById('rendelesHazszam');

            if (!select) return;

            function fillFromSelected() {
                const option = select.options[select.selectedIndex];
                if (!option || !option.value) return;

                nev.value = option.dataset.nev || '';
                szemelyi.value = option.dataset.szemelyi || '';
                iranyitoszam.value = option.dataset.iranyitoszam || '';
                varos.value = option.dataset.varos || '';
                utca.value = option.dataset.utca || '';
                hazszam.value = option.dataset.hazszam || '';
            }

            select.addEventListener('change', fillFromSelected);

            if (select.value) {
                fillFromSelected();
            }
        })();
    </script>
}