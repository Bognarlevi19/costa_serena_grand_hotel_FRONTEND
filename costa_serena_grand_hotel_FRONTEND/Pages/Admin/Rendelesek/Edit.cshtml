@page "{id:int}"
@model costa_serena_grand_hotel_FRONTEND.Pages.Admin.Rendelesek.EditModel
@{
    ViewData["Title"] = "Rendelés módosítása";
}

<section class="section-soft admin-page-section">
    <div class="container admin-crud-container">
        @{
            ViewData["AdminTitle"] = "Rendelés módosítása";
            ViewData["AdminSubTitle"] = "A rendelés adatai és állapotai itt szerkeszthetők.";
            ViewData["AdminBackPage"] = "/Admin/Index";
        }
        <partial name="_AdminCrudHeader" />

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">
                @Model.ErrorMessage
            </div>
        }

        <div class="admin-crud-card">
            <form method="post" class="row g-4">
                <input asp-for="Rendeles.Id" type="hidden" />
                <input asp-for="Rendeles.VendegId" type="hidden" />
                <input asp-for="Rendeles.Vegosszeg" type="hidden" />
                <input asp-for="Rendeles.Letrehozva" type="hidden" />

                <div class="col-12 col-md-6">
                    <label asp-for="Rendeles.Nev" class="form-label fw-semibold">Név</label>
                    <input asp-for="Rendeles.Nev" class="form-control form-control-lg rounded-4" />
                    <span asp-validation-for="Rendeles.Nev" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="Rendeles.SzemelyiIgazolvanySzam" class="form-label fw-semibold">Személyi igazolvány szám</label>
                    <input asp-for="Rendeles.SzemelyiIgazolvanySzam" class="form-control form-control-lg rounded-4" />
                    <span asp-validation-for="Rendeles.SzemelyiIgazolvanySzam" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="Rendeles.IranyitoSzam" class="form-label fw-semibold">Irányítószám</label>
                    <input asp-for="Rendeles.IranyitoSzam" class="form-control form-control-lg rounded-4" />
                    <span asp-validation-for="Rendeles.IranyitoSzam" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="Rendeles.Varos" class="form-label fw-semibold">Város</label>
                    <input asp-for="Rendeles.Varos" class="form-control form-control-lg rounded-4" />
                    <span asp-validation-for="Rendeles.Varos" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="Rendeles.Hazszam" class="form-label fw-semibold">Házszám</label>
                    <input asp-for="Rendeles.Hazszam" class="form-control form-control-lg rounded-4" />
                    <span asp-validation-for="Rendeles.Hazszam" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Rendeles.Utca" class="form-label fw-semibold">Utca</label>
                    <input asp-for="Rendeles.Utca" class="form-control form-control-lg rounded-4" />
                    <span asp-validation-for="Rendeles.Utca" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label fw-semibold">Létrehozva</label>
                    <input class="form-control form-control-lg rounded-4"
                           value="@Model.Rendeles.Letrehozva.ToLocalTime().ToString("yyyy.MM.dd HH:mm")"
                           readonly />
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label fw-semibold">Végösszeg</label>
                    <input class="form-control form-control-lg rounded-4"
                           value="@($"{Model.Rendeles.Vegosszeg:N0} Ft")"
                           readonly />
                </div>

                <div class="col-12 col-md-6">
                    <div class="form-check form-switch fs-5 pt-3">
                        <input asp-for="Rendeles.Fizetett" class="form-check-input" />
                        <label asp-for="Rendeles.Fizetett" class="form-check-label fw-semibold">Fizetett</label>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="form-check form-switch fs-5 pt-3">
                        <input asp-for="Rendeles.Elkuldve" class="form-check-input" />
                        <label asp-for="Rendeles.Elkuldve" class="form-check-label fw-semibold">Elküldött</label>
                    </div>
                </div>

                <div class="col-12 d-flex flex-wrap gap-2 pt-2">
                    <button type="submit" class="btn btn-dark rounded-pill px-4">Mentés</button>
                    <a asp-page="/Admin/Rendelesek/Index" class="btn btn-outline-dark rounded-pill px-4">Vissza a listához</a>
                    <a asp-page="/Admin/Index" class="btn btn-outline-secondary rounded-pill px-4">Admin menü</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}