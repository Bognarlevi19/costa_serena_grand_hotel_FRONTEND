@page
@model costa_serena_grand_hotel_FRONTEND.Pages.Admin.Rendelesek.IndexModel
@{
    ViewData["Title"] = "Rendelések";
    ViewData["AdminTitle"] = "Rendelések";
    ViewData["AdminSubTitle"] = "Rendelések listája, módosítása, törlése és hozzáadása.";
    ViewData["AdminBackPage"] = "/Admin/Index";
    ViewData["AdminAddPage"] = "/Admin/Rendelesek/Create";
    ViewData["AdminAddText"] = "Új rendelés hozzáadása";
}

<section class="section-soft admin-page-section">
    <div class="container admin-crud-container">
        <partial name="_AdminCrudHeader" />

        @if (TempData["AdminError"] != null)
        {
            <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">@TempData["AdminError"]</div>
        }

        <div class="admin-crud-card">
            <div class="table-responsive">
                <table class="table admin-table align-middle">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Név</th>
                            <th>Létrehozva</th>
                            <th>Végösszeg</th>
                            <th>Fizetett</th>
                            <th>Elküldött</th>
                            <th class="admin-actions-cell">Műveletek</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Rendelesek.Any())
                        {
                            @foreach (var item in Model.Rendelesek)
                            {
                                <tr class="@(item.Elkuldve ? "admin-line-through" : "")">
                                    <td>@item.Id</td>
                                    <td>@item.Nev</td>
                                    <td>@item.Letrehozva.ToLocalTime().ToString("yyyy.MM.dd HH:mm")</td>
                                    <td>@item.Vegosszeg Ft</td>
                                    <td>@(item.Fizetett ? "Igen" : "Nem")</td>
                                    <td>
                                        <form method="post" asp-page-handler="ToggleElkuldve" asp-route-id="@item.Id" class="d-flex align-items-center gap-2">
                                            <input type="hidden" name="elkuldve" value="@(item.Elkuldve ? "false" : "true")" />
                                            <input type="checkbox" class="form-check-input" @(item.Elkuldve ? "checked" : null) onchange="this.form.submit()" />
                                        </form>
                                    </td>
                                    <td class="admin-actions-cell">
                                        <div class="d-flex gap-2 flex-wrap">
                                            <a asp-page="/Admin/Rendelesek/Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Módosítás</a>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Biztosan törlöd?');">
                                                <button type="submit" class="btn btn-sm btn-danger">Törlés</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="admin-empty">Nincs megjeleníthető adat.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>