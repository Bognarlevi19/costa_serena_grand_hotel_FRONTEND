@page "{id:int}"
@model costa_serena_grand_hotel_FRONTEND.Pages.Admin.SzobaKategoriak.EditModel
@{
    ViewData["Title"] = "Szobakategória szerkesztése";
    ViewData["AdminTitle"] = "Szobakategória szerkesztése";
    ViewData["AdminSubTitle"] = "Adatok módosítása és képek cseréje.";
    ViewData["AdminBackPage"] = "/Admin/SzobaKategoriak/Index";
}

<section class="section-soft admin-page-section">
    <div class="container admin-crud-container">
        <partial name="_AdminCrudHeader" />

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">
                @Model.ErrorMessage
            </div>
        }

        <div class="admin-crud-card">
            <form method="post" enctype="multipart/form-data">
                <input asp-for="Kategoria.Id" type="hidden" />
                <input asp-for="Kategoria.KepekJson" type="hidden" />

                <div class="admin-form-grid">
                    <div class="admin-col-12">
                        <label asp-for="Kategoria.Nev" class="form-label">Név</label>
                        <input asp-for="Kategoria.Nev" class="form-control form-soft rounded-4" />
                        <span asp-validation-for="Kategoria.Nev" class="text-danger small"></span>
                    </div>

                    <div class="admin-col-12">
                        <label asp-for="Kategoria.Leiras" class="form-label">Leírás</label>
                        <textarea asp-for="Kategoria.Leiras" class="form-control form-soft rounded-4" rows="4"></textarea>
                        <span asp-validation-for="Kategoria.Leiras" class="text-danger small"></span>
                    </div>

                    <div class="admin-col-12">
                        <label class="form-label">Jelenlegi képek</label>

                        @if (Model.CurrentImages.Any())
                        {
                            <div class="row g-3 mb-3">
                                @foreach (var kep in Model.CurrentImages)
                                {
                                    <div class="col-6 col-md-4 col-xl-3">
                                        <div class="border rounded-4 p-2 h-100 bg-white shadow-sm">
                                            <img src="@kep" class="img-fluid rounded-3 mb-2" style="height:180px; width:100%; object-fit:cover;" />
                                            <div class="small text-break text-body-secondary">@kep</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-body-secondary mb-3">Ehhez a kategóriához még nincs kép feltöltve.</div>
                        }
                    </div>

                    <div class="admin-col-12">
                        <label class="form-label">Új képek hozzáadása</label>

                        <div class="admin-image-dropzone rounded-4 p-4 text-center"
                             data-dropzone
                             data-input="#UploadedImages"
                             data-list="#uploadedImageList">
                            <div class="fw-semibold mb-2">Húzd ide a képeket</div>
                            <div class="text-body-secondary small mb-3">vagy kattints és válaszd ki őket</div>

                            <input type="file"
                                   id="UploadedImages"
                                   name="UploadedImages"
                                   multiple
                                   accept=".jpg,.jpeg,.png,.webp"
                                   class="form-control rounded-4" />
                        </div>

                        <div id="uploadedImageList" class="small text-body-secondary mt-3"></div>
                    </div>
                </div>

                <div class="admin-form-actions mt-4 d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-success rounded-pill px-4">Mentés</button>
                    <a asp-page="/Admin/SzobaKategoriak/Index" class="btn btn-outline-secondary rounded-pill px-4">Vissza a listához</a>
                    <a asp-page="/Admin/Index" class="btn btn-outline-dark rounded-pill px-4">Admin menü</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}