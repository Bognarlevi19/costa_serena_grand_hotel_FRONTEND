@page
@model costa_serena_grand_hotel_FRONTEND.Pages.Admin.SzobaKategoriak.IndexModel
@{
    ViewData["Title"] = "Szobakategóriák";
    ViewData["AdminTitle"] = "Szobakategóriák";
    ViewData["AdminSubTitle"] = "Kategóriák listája, szerkesztése, törlése és hozzáadása.";
    ViewData["AdminBackPage"] = "/Admin/Index";
    ViewData["AdminAddPage"] = "/Admin/SzobaKategoriak/Create";
    ViewData["AdminAddText"] = "Új szobakategória hozzáadása";
}

<section class="section-soft admin-page-section">
    <div class="container admin-crud-container">
        <partial name="_AdminCrudHeader" />

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">@Model.ErrorMessage</div>
        }

        <div class="admin-crud-card">
            <div class="table-responsive">
                <table class="table admin-table align-middle">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Név</th>
                            <th>Leírás</th>
                            <th>Darab</th>
                            <th class="admin-actions-cell">Műveletek</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Kategoriak.Any())
                        {
                            @foreach (var item in Model.Kategoriak)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.Nev</td>
                                    <td>@item.Leiras</td>
                                    <td>@item.Darab</td>
                                    <td class="admin-actions-cell">
                                        <div class="d-flex gap-2 flex-wrap">
                                            <a asp-page="/Admin/SzobaKategoriak/Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Szerkesztés</a>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Biztosan törlöd?');">
                                                <button type="submit" class="btn btn-sm btn-danger">Törlés</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="admin-empty">Nincs megjeleníthető adat.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>