@page
@model costa_serena_grand_hotel_FRONTEND.Pages.Admin.UserDetailsModel
@{
    ViewData["Title"] = "Felhasználó részletei";
}

<section class="section-soft py-5">
    <div class="container py-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
                <a asp-page="/Admin/Users" class="btn btn-outline-dark rounded-pill px-4">← Vissza a felhasználókhoz</a>
            </div>
            <div>
                <a asp-page="/Admin/Index" class="btn btn-outline-secondary rounded-pill px-4">Dashboard</a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger rounded-4 border-0 shadow-sm">@Model.ErrorMessage</div>
        }
        else if (Model.UserDetails != null)
        {
            <div class="row g-4 mb-4">
                <div class="col-12 col-xl-7">
                    <div class="glass rounded-5 p-4 h-100">
                        <h1 class="h3 fw-semibold mb-4">Felhasználói adatok</h1>

                        <div class="admin-detail-grid">
                            <div>
                                <div class="admin-detail-label">Felhasználó ID</div>
                                <div class="admin-detail-value">@Model.UserDetails.User.UserId</div>
                            </div>
                            <div>
                                <div class="admin-detail-label">E-mail</div>
                                <div class="admin-detail-value">@Model.UserDetails.User.Email</div>
                            </div>
                            <div>
                                <div class="admin-detail-label">Felhasználónév</div>
                                <div class="admin-detail-value">@Model.UserDetails.User.UserName</div>
                            </div>
                            <div>
                                <div class="admin-detail-label">Szerepkörök</div>
                                <div class="admin-detail-value">
                                    @foreach (var role in Model.UserDetails.User.Roles)
                                    {
                                        <span class="badge @(role == "Admin" ? "bg-danger" : "bg-warning text-dark") me-1">@role</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-5">
                    <div class="glass rounded-5 p-4 h-100">
                        <h2 class="h4 mb-4">Statisztikák</h2>

                        <div class="vstack gap-3">
                            <div class="admin-mini-stat">
                                <span>Összes művelet</span>
                                <strong>@Model.UserDetails.Stats.TotalActions</strong>
                            </div>
                            <div class="admin-mini-stat">
                                <span>Sikertelen belépések</span>
                                <strong>@Model.UserDetails.Stats.FailedLogins</strong>
                            </div>
                            <div class="admin-mini-stat">
                                <span>Utolsó aktivitás</span>
                                <strong>@(Model.UserDetails.Stats.LastActivity?.ToLocalTime().ToString("yyyy.MM.dd. HH:mm") ?? "-")</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="glass rounded-5 p-4">
                <h2 class="h4 mb-3">Legutóbbi logok</h2>

                <div class="table-responsive">
                    <table class="table align-middle admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Időpont</th>
                                <th>Metódus</th>
                                <th>Útvonal</th>
                                <th>Státusz</th>
                                <th>Üzenet</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.UserDetails.RecentLogs)
                            {
                                <tr>
                                    <td>@log.Timestamp.ToLocalTime().ToString("yyyy.MM.dd. HH:mm:ss")</td>
                                    <td>@log.HttpMethod</td>
                                    <td>@log.Path</td>
                                    <td>@log.StatusCode</td>
                                    <td>@log.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>