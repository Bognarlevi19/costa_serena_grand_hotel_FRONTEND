@page
@model costa_serena_grand_hotel_FRONTEND.Pages.Admin.Vendegek.CreateModel
@{
    ViewData["Title"] = "Új vendég";
    ViewData["AdminTitle"] = "Új vendég";
    ViewData["AdminSubTitle"] = "Új vendég létrehozása.";
    ViewData["AdminBackPage"] = "/Admin/Vendegek/Index";
}

<section class="section-soft admin-page-section">
    <div class="container admin-crud-container">
        <partial name="_AdminCrudHeader" />

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">@Model.ErrorMessage</div>
        }

        <div class="admin-crud-card">
            <form method="post">
                <div class="admin-form-grid">
                    <div class="admin-col-6">
                        <label asp-for="Vendeg.Nev" class="form-label">Név</label>
                        <input asp-for="Vendeg.Nev" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-6">
                        <label asp-for="Vendeg.SzemelyiIgazolvanySzam" class="form-label">Személyi igazolvány szám</label>
                        <input asp-for="Vendeg.SzemelyiIgazolvanySzam" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-4">
                        <label asp-for="Vendeg.IranyitoSzam" class="form-label">Irányítószám</label>
                        <input asp-for="Vendeg.IranyitoSzam" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-4">
                        <label asp-for="Vendeg.Varos" class="form-label">Város</label>
                        <input asp-for="Vendeg.Varos" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-4">
                        <label asp-for="Vendeg.Hazszam" class="form-label">Házszám</label>
                        <input asp-for="Vendeg.Hazszam" class="form-control form-soft rounded-4" />
                    </div>

                    <div class="admin-col-12">
                        <label asp-for="Vendeg.Utca" class="form-label">Utca</label>
                        <input asp-for="Vendeg.Utca" class="form-control form-soft rounded-4" />
                    </div>
                </div>

                <div class="admin-form-actions">
                    <button type="submit" class="btn btn-success rounded-pill px-4">Mentés</button>
                    <a asp-page="/Admin/Vendegek/Index" class="btn btn-outline-secondary rounded-pill px-4">Mégse</a>
                </div>
            </form>
        </div>
    </div>
</section>