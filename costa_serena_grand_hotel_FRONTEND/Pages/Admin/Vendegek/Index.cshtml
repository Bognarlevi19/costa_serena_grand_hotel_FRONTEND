@page
@model costa_serena_grand_hotel_FRONTEND.Pages.Admin.Vendegek.IndexModel
@{
    ViewData["Title"] = "Vendégek";
    ViewData["AdminTitle"] = "Vendégek";
    ViewData["AdminSubTitle"] = "Vendégek listája, szerkesztése, törlése és hozzáadása.";
    ViewData["AdminBackPage"] = "/Admin/Index";
    ViewData["AdminAddPage"] = "/Admin/Vendegek/Create";
    ViewData["AdminAddText"] = "Új vendég hozzáadása";
}

<section class="section-soft admin-page-section">
    <div class="container admin-crud-container">
        <partial name="_AdminCrudHeader" />

        @if (TempData["AdminError"] != null)
        {
            <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">@TempData["AdminError"]</div>
        }

        <div class="admin-crud-card">
            <div class="table-responsive">
                <table class="table admin-table align-middle">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Név</th>
                            <th>Személyi igazolvány</th>
                            <th>Irányítószám</th>
                            <th>Város</th>
                            <th>Utca</th>
                            <th>Házszám</th>
                            <th class="admin-actions-cell">Műveletek</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Vendegek.Any())
                        {
                            @foreach (var item in Model.Vendegek)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.Nev</td>
                                    <td>@item.SzemelyiIgazolvanySzam</td>
                                    <td>@item.IranyitoSzam</td>
                                    <td>@item.Varos</td>
                                    <td>@item.Utca</td>
                                    <td>@item.Hazszam</td>
                                    <td class="admin-actions-cell">
                                        <div class="d-flex gap-2 flex-wrap">
                                            <a asp-page="/Admin/Vendegek/Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Szerkesztés</a>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Biztosan törlöd?');">
                                                <button type="submit" class="btn btn-sm btn-danger">Törlés</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="admin-empty">Nincs megjeleníthető adat.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>