@page
@model costa_serena_grand_hotel_FRONTEND.Pages.ContactModel
@{
    ViewData["Title"] = "Kapcsolat";
}

<section class="hero hero-sm d-flex align-items-end position-relative">
    <div class="hero-media">
        <img class="hero-image" src="/kepek/hotelcontactkep.png" alt="Kapcsolat - Costa Serena Grand Hotel" />
        <div class="hero-overlay hero-overlay-soft"></div>
    </div>

    <div class="container position-relative pb-5">
        <div class="row">
            <div class="col-lg-8">
                <p class="small text-uppercase ls text-hero-muted mb-2">KAPCSOLAT • ELÉRHETŐSÉGEK • ÜZENET</p>
                <h1 class="display-5 fw-semibold mb-3 text-hero">Kapcsolat</h1>
                <p class="lead text-dark mb-4">
                    Írjon nekünk üzenetet, vagy keressen telefonon — segítünk a foglalásban, ajánlatokban és bármilyen kérdésben.
                </p>

                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-dark rounded-pill px-4" href="#form">Üzenet küldése</a>
                    <a class="btn btn-outline-dark rounded-pill px-4" href="#map">Térkép</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="social" class="py-5 bg-white border-top">
    <div class="container py-4">

        <div class="text-center mb-5">
            <div class="small text-uppercase ls text-body-secondary mb-2">
                Kövessen minket
            </div>
            <h2 class="display-6 fw-semibold">
                Kapcsolódjon a Costa Serena világához.
            </h2>
        </div>

        <div class="row justify-content-center g-4">

            <!-- FACEBOOK -->
            <div class="col-6 col-md-3">
                <a href="https://www.facebook.com/levente.bognar.94"
                   target="_blank" rel="noopener"
                   class="social-card d-flex flex-column align-items-center justify-content-center text-decoration-none">
                    <i class="bi bi-facebook social-icon mb-3"></i>
                    <div class="fw-semibold text-dark">Facebook</div>
                </a>
            </div>

            <!-- INSTAGRAM -->
            <div class="col-6 col-md-3">
                <a href="https://www.instagram.com/mmbalint/"
                   target="_blank" rel="noopener"
                   class="social-card d-flex flex-column align-items-center justify-content-center text-decoration-none">
                    <i class="bi bi-instagram social-icon mb-3"></i>
                    <div class="fw-semibold text-dark">Instagram</div>
                </a>
            </div>

            <!-- TIKTOK -->
            <div class="col-6 col-md-3">
                <a href="https://www.instagram.com/marcibertha"
                   target="_blank" rel="noopener"
                   class="social-card d-flex flex-column align-items-center justify-content-center text-decoration-none">
                    <i class="bi bi-tiktok social-icon mb-3"></i>
                    <div class="fw-semibold text-dark">TikTok</div>
                </a>
            </div>

        </div>

    </div>
</section>
<section class="py-5 section-paper">
    <div class="container py-4">
        <div class="row g-4 align-items-stretch" id="form">

            <!-- BAL: Elérhetőségek -->
            <div class="col-lg-5">
                <div class="glass rounded-4 p-4 p-lg-5 h-100">
                    <div class="small text-uppercase ls text-body-secondary mb-2">Elérhetőségek</div>
                    <h2 class="h3 fw-semibold mb-4">Costa Serena Grand Hotel</h2>

                    <div class="vstack gap-3 small">
                        <div>
                            <div class="text-body-secondary">Cím</div>
                            <div class="fw-semibold">Italy - Vieste, Via Venezia 1.</div>
                        </div>

                        <div>
                            <div class="text-body-secondary">Telefon</div>
                            <div class="fw-semibold">+39 39 3939 3939</div>
                        </div>

                        <div>
                            <div class="text-body-secondary">E-mail</div>
                            <div class="fw-semibold">info@costaserena.com</div>
                        </div>
                    </div>

                    <hr class="my-4 opacity-25" />

                    <div class="small text-uppercase ls text-body-secondary mb-2">Nyitvatartás</div>
                    <div class="small">
                        <div class="d-flex justify-content-between">
                            <span class="text-body-secondary">Recepció</span>
                            <span class="fw-semibold">0–24</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-body-secondary">Spa</span>
                            <span class="fw-semibold">08:00 – 21:00</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-body-secondary">Éttermek</span>
                            <span class="fw-semibold">07:00 – 23:00</span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <a class="btn btn-outline-dark rounded-pill px-4" href="#map">Útvonaltervezés</a>
                    </div>
                </div>
            </div>

            <!-- JOBB: Űrlap -->
            <div class="col-lg-7">
                <div class="glass rounded-4 p-4 p-lg-5 h-100">
                    <div class="small text-uppercase ls text-body-secondary mb-2">Üzenet küldése</div>
                    <h2 class="h3 fw-semibold mb-4">Írj nekünk</h2>

                    <form id="contactForm" class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small text-body-secondary">Név</label>
                            <input id="contactName" class="form-control form-soft" type="text" placeholder="Teljes név" value="@Model.PrefillName" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small text-body-secondary">E-mail</label>
                            <input id="contactEmail" class="form-control form-soft" type="email" placeholder="email@példa.hu" value="@Model.PrefillEmail" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small text-body-secondary">Telefon (opcionális)</label>
                            <input id="contactPhone" class="form-control form-soft" type="tel" placeholder="+36..." />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small text-body-secondary">Téma</label>
                            <select id="contactSubject" class="form-select form-soft">
                                <option selected>Általános kérdés</option>
                                <option>Foglalás</option>
                                <option>Ajánlatok</option>
                                <option>Rendezvény</option>
                                <option>Egyéb</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-body-secondary">Üzenet</label>
                            <textarea id="contactMessage" class="form-control form-soft" rows="5" placeholder="Írd ide az üzeneted..."></textarea>
                        </div>

                        <div class="col-12 d-flex flex-wrap align-items-center justify-content-between gap-2 mt-2">
                            <div class="small text-body-secondary">
                                Válaszidő: általában 24 órán belül.
                            </div>
                            <button class="btn btn-dark rounded-pill px-4" type="submit">Küldés</button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>
<div id="contactPopup" class="newsletter-popup">
    <div class="newsletter-popup-box">
        <div class="small text-uppercase ls text-body-secondary mb-2">Üzenet elküldve</div>
        <h4 class="fw-semibold mb-3" id="contactPopupTitle">Köszönjük üzenetét!</h4>
        <p class="text-body-secondary mb-0" id="contactPopupText">
            Hamarosan felvesszük Önnel a kapcsolatot.
        </p>
    </div>
</div>
<section id="services" class="py-5 section-paper">
    <div class="container py-4">

        <div class="text-center mb-5">
            <div class="small text-uppercase ls text-body-secondary mb-2">
                Kényelmi szolgáltatások
            </div>
            <h2 class="display-6 fw-semibold">
                Prémium élmény már az első pillanattól.
            </h2>
        </div>

        <div class="row g-4">

            <!-- PARKOLÁS -->
            <div class="col-md-6">
                <div class="glass rounded-4 overflow-hidden h-100 service-card">
                    <img src="/kepek/privatparkolo.png"
                         class="w-100 service-img clickable-img"
                         alt="Privát parkoló"
                         onclick="openImage(this.src)">

                    <div class="p-4">
                        <div class="small text-uppercase ls text-body-secondary mb-2">
                            Parkolás
                        </div>

                        <h5 class="fw-semibold mb-2">
                            Privát parkoló
                        </h5>

                        <div class="text-body-secondary small">
                            Helyszíni, őrzött parkoló elérhető vendégeink számára.
                        </div>
                    </div>
                </div>
            </div>

            <!-- TRANSZFER -->
            <div class="col-md-6">
                <div class="glass rounded-4 overflow-hidden h-100 service-card">
                    <img src="/kepek/transzfer.png"
                         class="w-100 service-img clickable-img"
                         alt="Reptéri transzfer"
                         onclick="openImage(this.src)">

                    <div class="p-4">
                        <div class="small text-uppercase ls text-body-secondary mb-2">
                            Transzfer
                        </div>

                        <h5 class="fw-semibold mb-2">
                            Reptéri transzfer
                        </h5>

                        <div class="text-body-secondary small">
                            Kérésre szervezett érkezés és indulás, kényelmes prémium járművekkel.
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>
</section>

<section id="map" class="py-5 section-soft">
    <div class="container py-4">

        <div class="text-center mb-5">
            <div class="small text-uppercase ls text-body-secondary mb-2">
                Térkép
            </div>
            <h2 class="display-6 fw-semibold">
                Találkozzunk a tengerpartnál.
            </h2>
        </div>

        <div class="glass rounded-4 overflow-hidden">
            <div id="hotel-map"></div>
        </div>

    </div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const apiKey = "ZimMt82QrXhN4JpSwDuF";

        const map = L.map('hotel-map').setView([41.8826, 16.1756], 15);

        L.tileLayer(`https://api.maptiler.com/maps/streets/{z}/{x}/{y}.png?key=${apiKey}`, {
            tileSize: 512,
            zoomOffset: -1,
            minZoom: 1,
            attribution: '&copy; MapTiler &copy; OpenStreetMap közreműködők'
        }).addTo(map);

        L.marker([41.8826, 16.1756])
            .addTo(map)
            .bindPopup('<b>Costa Serena Grand Hotel</b><br>Italy - Vieste, Via Venezia 1.')
            .openPopup();

            const contactForm = document.getElementById("contactForm");
        const contactName = document.getElementById("contactName");
        const contactEmail = document.getElementById("contactEmail");
        const contactPhone = document.getElementById("contactPhone");
        const contactSubject = document.getElementById("contactSubject");
        const contactMessage = document.getElementById("contactMessage");
        const contactPopup = document.getElementById("contactPopup");
        const contactPopupTitle = document.getElementById("contactPopupTitle");
        const contactPopupText = document.getElementById("contactPopupText");

        if (contactForm) {
            contactForm.addEventListener("submit", function (e) {
                e.preventDefault();

                const name = contactName.value.trim();
                const email = contactEmail.value.trim();
                const message = contactMessage.value.trim();

                if (name !== "" && email !== "" && message !== "") {
                    contactPopupTitle.textContent = `Köszönjük üzenetét, ${name}!`;
                    contactPopupText.textContent = "Hamarosan felvesszük Önnel a kapcsolatot.";

                    contactName.value = "";
                    contactEmail.value = "";
                    contactPhone.value = "";
                    contactSubject.selectedIndex = 0;
                    contactMessage.value = "";

                    contactPopup.classList.add("show");

                    setTimeout(() => {
                        contactPopup.classList.remove("show");
                    }, 3000);
            }
        });
    }
    });
</script>
<!-- ================================================= -->

