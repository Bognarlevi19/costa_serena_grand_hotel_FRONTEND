@page
@model costa_serena_grand_hotel_FRONTEND.Pages.IndexModel
@{
    ViewData["Title"] = "Főoldal";
}
@inject costa_serena_grand_hotel_FRONTEND.Services.AuthSession AuthSession


<!-- HERO -->
<section class="hero d-flex align-items-end position-relative">
    <div class="hero-media">
        <video class="hero-video" autoplay muted loop playsinline>
            <source src="/videok/HotelbemutatoVideo.mp4" type="video/mp4" />
        </video>
        <div class="hero-overlay"></div>
    </div>

    <div class="container position-relative pb-5">
        <div class="row">
            <div class="col-lg-8">
                <p class="small text-uppercase ls text-hero-muted mb-2">EXKLUZÍV • PRIVÁT • PRÉMIUM</p>
                <h1 class="display-5 fw-semibold mb-3 text-hero">A luxus valódi kezdete.</h1>
                <p class="lead mb-4 text-black">
                    Luxus medencék, pálmafák árnyéka és felejthetetlen esték egy igazán egyedi környezetben..
                </p>

                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-dark rounded-pill px-4" href="#story">Tudj meg többet</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STORY -->
<section id="story" class="py-5 py-lg-6 section-paper">
    <div class="container py-4">
        <div class="row g-5 align-items-center">
            <div class="col-lg-5">
                <p class="small text-uppercase ls text-body-secondary mb-2">A Costa Serena Grand Hotelről</p>
                <h2 class="fw-semibold mb-3 display-6">A luxus új értelmet kap.</h2>
                <p class="text-body-secondary mb-4">
                    Minden hotel egy helyszínre van hangolva: a hangulat, anyaghasználat, zene, illatok, fények.
                    Nem “lánc”, hanem kollekció.
                </p>

                <div class="glass border border-dark border-opacity-10 rounded-4 p-4">
                    <div class="fs-5">“Ahová egyszer megérkezel… és vissza akarsz térni.”</div>
                    <div class="small text-body-secondary mt-2">
                        <a class="link-dark text-decoration-none" asp-page="/Ertekelesek">— Vendégértékelések</a>

                     </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <!-- EXKLUZÍV SZOBA: kattintásra nagyítás -->
                        <a class="d-block feature-tile rounded-4 overflow-hidden border border-dark border-opacity-10 text-decoration-none text-dark tile"
                           href="#"
                           onclick="openImage('/kepek/LuxusSzoba.png'); return false;">
                            <img class="w-100 h-100 object-fit-cover clickable-img"
                                 alt="Prémium lakosztály"
                                 src="/kepek/LuxusSzoba.png"
                                 loading="lazy" />
                            <div class="tile-grad p-3">
                                <div class="small text-uppercase ls text-body-secondary">Exkluzív</div>
                                <div class="h4 mb-0">Prémium lakosztály</div>
                            </div>
                        </a>
                    </div>

                    <div class="col-12 col-md-6">
                        <!-- SPA: kattintásra nagyítás -->
                        <a class="d-block feature-tile rounded-4 overflow-hidden border border-dark border-opacity-10 text-decoration-none text-dark tile"
                           href="#"
                           onclick="openImage('/kepek/HotelSpa.png'); return false;">
                            <img class="w-100 h-100 object-fit-cover clickable-img"
                                 alt="Spa"
                                 src="/kepek/HotelSpa.png"
                                 loading="lazy" />
                            <div class="tile-grad p-3">
                                <div class="small text-uppercase ls text-body-secondary">Nyugalom</div>
                                <div class="h4 mb-0">Spa</div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- DINING -->
<section id="dining" class="py-5 section-soft">
    <div class="container py-4">
        <div class="d-flex align-items-end justify-content-between gap-3 mb-4">
            <div>
                <div class="small text-uppercase ls text-body-secondary">Éttermek &amp; Szórakozás</div>
                <h2 class="display-6 fw-semibold mb-0">Helyek, amelyeket érdemes kipróbálni.</h2>
            </div>
        </div>

        <div class="row g-3">
            @foreach (var it in Model.Elemek)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <a class="d-block rounded-4 overflow-hidden border border-dark border-opacity-10 text-decoration-none text-dark tile"
                       href="#"
                       onclick="openImage('@it.kep'); return false;">
                        <img class="w-100 tile-img clickable-img" alt="@it.cim" src="@it.kep" loading="lazy" />
                        <div class="tile-grad p-3">
                            <div class="small text-uppercase ls text-body-secondary">@it.tipus</div>
                            <div class="h5 mb-0">@it.cim</div>
                            <div class="small text-body-secondary">@it.hely</div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- SHOP -->
<section id="shop" class="py-5 section-paper">
    <div class="container py-4">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6">
                <div class="small text-uppercase ls text-body-secondary">Üzlet</div>
                <h2 class="display-6 fw-semibold mb-3">A Costa Serena élmény hazavihető..</h2>
                <p class="text-body-secondary mb-4">
                    Exkluzív illatok, prémium textíliák és gondosan válogatott kiegészítők, amelyek a tengerparti nyugalmat hozzák el otthonodba.
                </p>
                <a class="btn btn-dark rounded-pill px-4" asp-page="/Shop/Index">Kollekció megtekintése</a>
            </div>

            <div class="col-lg-6">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="glass border border-dark border-opacity-10 rounded-4 overflow-hidden">
                            <img class="w-100 zoom-img clickable-img"
                                 alt="Illatgyertya"
                                 loading="lazy"
                                 src="/kepek/Illatgyertya.png"
                                 onclick="openImage(this.src)" />
                            <div class="p-3">
                                <div class="small text-uppercase ls text-body-secondary">Illatgyertyák</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="glass border border-dark border-opacity-10 rounded-4 overflow-hidden">
                            <img class="w-100 zoom-img clickable-img"
                                 alt="Dísztakaró"
                                 loading="lazy"
                                 src="/kepek/disztakaro.png"
                                 onclick="openImage(this.src)" />
                            <div class="p-3">
                                <div class="small text-uppercase ls text-body-secondary">Dísztakarók</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="glass border border-dark border-opacity-10 rounded-4 overflow-hidden">
                            <img class="w-100 zoom-img clickable-img"
                                 height="320"
                                 alt="Costa Serena kollekció"
                                 loading="lazy"
                                 src="/kepek/shopkollekcio.png"
                                 onclick="openImage(this.src)" />
                            <div class="p-3">
                                <div class="small text-uppercase ls text-body-secondary">Costa Serena kollekció</div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>

<!-- OFFERS + NEWSLETTER -->
<section id="offers" class="py-5 section-soft">
    <div class="container py-4">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="glass border border-dark border-opacity-10 rounded-4 p-4 p-lg-5 h-100">
                    <div class="small text-uppercase ls text-body-secondary">Különleges ajánlatok</div>
                    <h2 class="display-6 fw-semibold mb-3">Exklúzív ajánlatok a Costa Serena Grand Hoteltől </h2>
                    <p class="text-body-secondary mb-4">
                        Wellness hétvégék, romantikus csomagok és személyre szabott pihenés a Costa Serena Grand Hotel Spa részlegében.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-dark rounded-pill px-4" asp-page="/Spa">Ajánlatok megtekintése</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-5" id="hirlevel">
                <div class="glass border border-dark border-opacity-10 rounded-4 p-4 p-lg-5 h-100">
                    <div class="small text-uppercase ls text-body-secondary">Hírlevél</div>
                    <h3 class="h4 mb-3">Értesüljön elsőként.</h3>

                    <form class="vstack gap-2" id="newsletterForm">
                        @if (AuthSession.IsSignedIn)
                        {
                            <div class="text-body-secondary small mb-1">
                                Bejelentkezve mint <strong>@AuthSession.GetEmail()</strong>
                            </div>
                        }
                        else
                        {
                            <input class="form-control form-soft" id="newsletterEmail" placeholder="Email cím" type="email" />
                        }

                        <button class="btn btn-outline-dark rounded-pill mt-2" type="submit">Feliratkozás</button>
                    </form>
                </div>
            </div>

            <div id="newsletterPopup" class="newsletter-popup">
                <div class="newsletter-popup-box">
                    <div class="small text-uppercase ls text-body-secondary mb-2">Sikeres feliratkozás</div>
                    <h4 class="fw-semibold mb-3" id="newsletterPopupTitle"></h4>
                    <p class="text-body-secondary mb-0">
                        Mostantól elsőként értesülhet az ajánlatainkról.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- FOOTER -->
<footer class="py-5 border-top border-dark border-opacity-10 section-paper">
    <div class="container">
        <div class="row g-5">

            <!-- KAPCSOLAT -->
            <div class="col-12 col-md-4">
                <h5 class="mb-3">Kapcsolat</h5>

                <div class="small text-body-secondary">
                    +39 39 3939 3939<br>
                    info@costaserena.com<br>
                    Italy - Vieste, Via Venezia 1.
                </div>

                <div class="small mt-3">
                    <a class="link-dark text-decoration-none" asp-page="/Index" asp-fragment="hirlevel">
                        Feliratkozás hírlevélre →
                    </a>
                </div>
            </div>

            <!-- INFORMÁCIÓK -->
            <div class="col-6 col-md-2 mx-md-auto">
                <h6 class="text-uppercase small text-body-secondary mb-3">Információk</h6>

                <div class="d-flex flex-column gap-2 small">
                    <a class="link-dark text-decoration-none" asp-page="/Contact">Kapcsolat</a>
                    <a class="link-dark text-decoration-none" asp-page="/Szobak/Index">Szobák</a>
                    <a class="link-dark text-decoration-none" asp-page="/Spa">Spa</a>
                    <a class="link-dark text-decoration-none" asp-page="/Webshop">Webshop</a>
                    <a class="link-dark text-decoration-none" asp-page="/Programok">Programok</a>
                    <a class="link-dark text-decoration-none" asp-page="/Shop">Shop</a>
                </div>
            </div>


            <!-- JOBB OLDAL -->
            <div class="col-12 col-md-4 ms-md-auto d-flex flex-column justify-content-between text-md-end align-items-md-end">
                <div>
                    <h6 class="text-uppercase small text-body-secondary mb-3">Costa Serena</h6>

                    <div class="small text-body-secondary">
                        Luxus, nyugalom és felejthetetlen élmények
                        a tengerpart szívében.
                    </div>
                </div>

                <div class="small text-body-secondary mt-4">
                    © @DateTime.Now.Year Costa Serena Grand Hotel<br>
                    Minden jog fenntartva.
                </div>
            </div>

        </div>
    </div>
</footer>


@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div id="foglalasKoszonoPopup" class="booking-popup-overlay">
        <div class="booking-popup-box">
            <div class="booking-popup-title">
                @(string.IsNullOrWhiteSpace(Model.PopupTitle) ? "Sikeres foglalás" : Model.PopupTitle)
            </div>
            <div class="booking-popup-text">@Model.SuccessMessage</div>
            <button type="button" class="btn btn-dark rounded-pill px-4 mt-3" onclick="closeBookingPopup()">
                Rendben
            </button>
        </div>
    </div>
}

<script>
    function closeBookingPopup() {
        var popup = document.getElementById("foglalasKoszonoPopup");
        if (popup) {
            popup.style.display = "none";
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById("newsletterForm");
        const input = document.getElementById("newsletterEmail");
        const popup = document.getElementById("newsletterPopup");
        const popupTitle = document.getElementById("newsletterPopupTitle");
        const signedInEmail = "@(AuthSession.IsSignedIn? AuthSession.GetEmail() ?? "" : "")";

        form.addEventListener("submit", function (e) {
            e.preventDefault();

            const email = signedInEmail || input?.value.trim() || "";

            if (email !== "") {
                popupTitle.textContent = `Köszönjük a feliratkozást, ${email}`;

                if (input) {
                    input.value = "";
                }

                popup.classList.add("show");

                setTimeout(() => {
                    popup.classList.remove("show");
                }, 3000);
            }
        });
    });
</script>