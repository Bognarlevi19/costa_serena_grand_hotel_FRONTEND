                    <div class="p-4">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Kultúra</div>
                        <h5 class="fw-semibold mb-2">Városnézés</h5>
                        <p class="text-body-secondary mb-3">
                            Fedezze fel a környék történelmi és kulturális értékeit.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Vízipark -->
            <div class="col-md-6 col-lg-4">
                <div class="glass rounded-4 overflow-hidden h-100 program-card">
                    <img src="/Kepek/programok/Vidám csúszás a víziparkban.png" class="w-100 program-img zoom-img" alt="Vízipark" />
                    <div class="p-4">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Család</div>
                        <h5 class="fw-semibold mb-2">Családi vízipark</h5>
                        <p class="text-body-secondary mb-3">
                            Tökéletes választás, ha az egész család számára
                            szeretne aktív és vidám programot.
                        </p>
                    </div>
                </div>
            </div>

            @* Minigolf *@
            <div class="col-md-6 col-lg-4">
                <div class="glass rounded-4 overflow-hidden h-100 program-card">
                    <img src="/Kepek/programok/minigolf.jpg" class="w-100 program-img zoom-img" alt="Minigolf" />
                    <div class="p-4">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Család • Szabadidő</div>
                        <h5 class="fw-semibold mb-2">Minigolf</h5>
                        <p class="text-body-secondary mb-3">
                            Élvezze a könnyed kikapcsolódást barátaival vagy családjával
                            egy vidám, hangulatos minigolfpályán.
                        </p>
                    </div>
                </div>
            </div>







        </div>

        <!-- CTA -->
        <div id="programszervezes" class="mt-5">
            <div class="glass rounded-4 p-4 p-lg-5">
                <div class="row align-items-center g-3">
                    <div class="col-lg-8">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Concierge szolgáltatás</div>
                        <h3 class="fw-semibold mb-2">Segítünk a programok megszervezésében</h3>
                        <p class="text-body-secondary mb-0">
                            Kérjük, forduljon recepciónkhoz bizalommal – munkatársaink
                            örömmel segítenek a foglalásban és az időpont-egyeztetésben.
                        </p>
                    </div>
                    <div class="col-lg-4 text-lg-end">
                        <a href="/Contact" class="btn btn-dark rounded-pill px-4 py-2">
                            Érdeklődés a programokról
                        </a>
                    </div>
                </div>
            </div>
        </div>
</section>

<!-- Kep scriptek -->
<script>
    function openImage(src) {
        const modal = document.getElementById("imgModal");
        const img = document.getElementById("imgModalContent");

        img.src = src;
        modal.style.display = "flex";
        document.body.style.overflow = "hidden";
    }

    function closeImage() {
        const modal = document.getElementById("imgModal");
        const img = document.getElementById("imgModalContent");

        modal.style.display = "none";
        img.src = "";
        document.body.style.overflow = "";
    }

    document.addEventListener("DOMContentLoaded", function () {
        const images = document.querySelectorAll(".zoom-img");

        images.forEach(function (image) {
            image.style.cursor = "zoom-in";

            image.addEventListener("click", function () {
                openImage(this.src);
            });
        });
    });

    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") closeImage();
    });
</script>

