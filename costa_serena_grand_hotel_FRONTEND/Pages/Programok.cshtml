                <h2 class="display-6 fw-semibold mb-0">
                    Tegye még emlékezetesebbé pihenését.
                </h2>
            </div>
        </div>

        <div class="row g-4">

            <!-- Jetski -->
            <div class="col-md-6 col-lg-4 d-flex">
                <div class="glass rounded-4 overflow-hidden h-100 w-100 program-card">
                    <img src="/Kepek/programok/Gyors hajózás a trópusi vízen.png"
                         class="w-100 program-img zoom-img"
                         alt="Jetski élmény" />
                    <div class="p-4 d-flex flex-column">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Víz • Adrenalin</div>
                        <h5 class="fw-semibold mb-2">Jetski élmény</h5>
                        <p class="text-body-secondary mb-3">
                            Tapasztalja meg a sebesség és a szabadság érzését
                            biztonságos környezetben, szakértői felügyelettel.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Quad -->
            <div class="col-md-6 col-lg-4">
                <div class="glass rounded-4 overflow-hidden h-100 program-card">
                    <img src="/Kepek/programok/Kalandos robogás a napsütésben.png" class="w-100 program-img zoom-img" alt="Quad túra" />
                    <div class="p-4">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Kaland • Terep</div>
                        <h5 class="fw-semibold mb-2">Vezetett quad túra</h5>
                        <p class="text-body-secondary mb-3">
                            Fedezze fel a környék rejtett útvonalait és
                            panorámás tájait izgalmas, mégis biztonságos túrák keretében.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Hajó -->
            <div class="col-md-6 col-lg-4">
                <div class="glass rounded-4 overflow-hidden h-100 program-card">
                    <img src="/Kepek/programok/Naplemente a jacht fedélzetén.png" class="w-100 program-img zoom-img" alt="Hajókirándulás" />
                    <div class="p-4">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Víz • Panoráma</div>
                        <h5 class="fw-semibold mb-2">Naplementés hajókirándulás</h5>
                        <p class="text-body-secondary mb-3">
                            Élvezze a víz nyugalmát és a lenyűgöző naplementét
                            egy elegáns, vezetett hajóút során.
                        </p>
                    </div>
                </div>
            </div>

            <!-- SUP -->
            <div class="col-md-6 col-lg-4">
                <div class="glass rounded-4 overflow-hidden h-100 program-card">
                    <img src="/Kepek/programok/Vízisport a trópusi parton.png" class="w-100 program-img zoom-img" alt="SUP" />
                    <div class="p-4">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Sport • Kikapcsolódás</div>
                        <h5 class="fw-semibold mb-2">SUP & Kajak</h5>
                        <p class="text-body-secondary mb-3">
                            Mozogjon a természetben, és fedezze fel a part menti
                            szakaszokat saját tempójában.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Strand -->
            <div class="col-md-6 col-lg-4">
                <div class="glass rounded-4 overflow-hidden h-100 program-card">
                    <img src="/Kepek/programok/Tengerparti pihenés koktélokkal.png" class="w-100 program-img zoom-img" alt="Strand" />
                    <div class="p-4">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Pihenés • Napfény</div>
                        <h5 class="fw-semibold mb-2">Exkluzív strandélmény</h5>
                        <p class="text-body-secondary mb-3">
                            Töltődjön fel napfényben, kényelmes napágyakon,
                            prémium kiszolgálás mellett.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Kerékpár -->
