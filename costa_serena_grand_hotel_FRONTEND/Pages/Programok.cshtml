                <div class="glass rounded-4 overflow-hidden h-100 program-card">
                    <img src="/Kepek/programok/lovaglasjo.png" class="w-100 program-img zoom-img" alt="Lovaglás" />
                    <div class="p-4">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Élmény • Természet</div>
