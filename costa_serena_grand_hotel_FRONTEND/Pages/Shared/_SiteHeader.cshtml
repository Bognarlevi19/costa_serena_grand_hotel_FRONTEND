@inject costa_serena_grand_hotel_FRONTEND.Services.AuthSession AuthSession
@inject costa_serena_grand_hotel_FRONTEND.Services.CartService CartService

@{
    var cartCount = CartService.GetCount();
}

<header class="position-fixed top-0 start-0 end-0 z-3 header-glass">
    <nav class="container py-2">
        <div class="header-shell">
            <div class="header-left">
                <a class="header-cart-pill"
                   asp-page="/Shop/Cart"
                   title="Kosár">
                    <span class="header-cart-icon-wrap" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="9" cy="20" r="1"></circle>
                            <circle cx="18" cy="20" r="1"></circle>
                            <path d="M2 3h2l2.2 10.2a2 2 0 0 0 2 1.6h8.7a2 2 0 0 0 2-1.6L21 7H6"></path>
                        </svg>
                    </span>
                    <span class="header-cart-label">Kosár</span>
                    <span class="header-cart-badge">@cartCount</span>
                </a>

                @if (AuthSession.IsSignedIn && !AuthSession.IsInRole("Admin"))
                {
                    <a class="header-bookings-pill"
                       asp-page="/Foglalasaim"
                       title="Foglalásaim">
                        Foglalásaim
                    </a>
                }

                <button class="btn btn-link text-dark text-decoration-none p-0 d-flex align-items-center gap-2 header-menu-btn"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#menu"
                        aria-controls="menu">
                    <span class="hamburger" aria-hidden="true"><span></span></span>
                    <span class="small text-uppercase ls mb-0">Menü</span>
                </button>
            </div>

            <div class="header-center">
                <a class="text-dark text-decoration-none fw-semibold ls hotel-brand" asp-page="/Index">
                    Costa Serena Grand Hotel
                </a>
            </div>

            <div class="header-right">
                @if (!AuthSession.IsSignedIn)
                {
                    <a class="btn btn-outline-dark btn-sm rounded-pill px-3" asp-page="/Account/Login">
                        Bejelentkezés
                    </a>
                    <a class="btn btn-dark btn-sm rounded-pill px-3" asp-page="/Account/Register">
                        Regisztráció
                    </a>
                }
                else
                {
                    <div class="header-user-box">
                        <span class="small text-uppercase ls text-body-secondary mb-0 header-user-email">
                            @AuthSession.GetEmail()
                        </span>

                        @if (AuthSession.IsInRole("Admin"))
                        {
                            <span class="badge bg-danger">Admin</span>
                        }
                        else if (AuthSession.IsInRole("User"))
                        {
                            <span class="badge bg-warning text-dark">User</span>
                        }
                    </div>

                    <form method="post" asp-page="/Account/Logout" class="d-inline mb-0">
                        <button type="submit" class="btn btn-outline-dark btn-sm rounded-pill px-3">
                            Kijelentkezés
                        </button>
                    </form>
                }
            </div>
        </div>
    </nav>
</header>

<div class="offcanvas offcanvas-start bg-white text-dark" tabindex="-1" id="menu">
    <div class="offcanvas-header border-bottom border-dark border-opacity-10">
        <h5 class="offcanvas-title ls">MENÜ</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>

    <div class="offcanvas-body">
        <div class="vstack gap-2">
            @if (AuthSession.IsSignedIn && !AuthSession.IsInRole("Admin"))
            {
                <a class="link-dark text-decoration-none" asp-page="/Vendeg/Index">Adataim</a>
            }
            <a class="link-dark text-decoration-none" asp-page="/Index">Főoldal</a>
            <a class="link-dark text-decoration-none" asp-page="/Contact">Kapcsolat</a>
            <a class="link-dark text-decoration-none" asp-page="/Ertekelesek">Értékelések</a>
            <a class="link-dark text-decoration-none" asp-page="/Programok">Programok</a>
            <a class="link-dark text-decoration-none" asp-page="/Spa">Wellness & Spa</a>
            <a class="link-dark text-decoration-none" asp-page="/Szobak/Index">Szobák megtekintése</a>
            <a class="link-dark text-decoration-none" asp-page="/Shop/Index">Shop</a>
            <a class="link-dark text-decoration-none d-flex align-items-center justify-content-between" asp-page="/Shop/Cart">
                <span>Kosár</span>
                <span class="offcanvas-cart-badge">@cartCount</span>
            </a>
            @if (AuthSession.IsInRole("Admin"))
            {
                <a class="link-dark text-decoration-none" asp-page="/Admin/Index">Admin felület</a>
            }
        </div>

        <hr class="my-4 opacity-25" />

        <div class="small text-uppercase ls text-body-secondary mb-2">Gyors elérés</div>
        <div class="vstack gap-2">
            <a class="link-dark text-decoration-none" asp-page="/Index" asp-fragment="story">Főoldal - Rólunk</a>
            <a class="link-dark text-decoration-none" asp-page="/Index" asp-fragment="dining">Étterem & bárok</a>
            <a class="link-dark text-decoration-none" asp-page="/Index" asp-fragment="shop">Ajándékok</a>
            <a class="link-dark text-decoration-none" asp-page="/Index" asp-fragment="offers">Ajánlatok</a>
            <a class="link-dark text-decoration-none" asp-page="/Index" asp-fragment="hirlevel">Hírlevél</a>

            <a class="link-dark text-decoration-none" asp-page="/Programok" asp-fragment="programok">Programok</a>
            <a class="link-dark text-decoration-none" asp-page="/Programok" asp-fragment="programszervezes">Programszervezés</a>

            <a class="link-dark text-decoration-none" asp-page="/Contact" asp-fragment="social">Közösségi oldalak</a>
            <a class="link-dark text-decoration-none" asp-page="/Contact" asp-fragment="form">Üzenetküldés</a>
            <a class="link-dark text-decoration-none" asp-page="/Contact" asp-fragment="services">Szolgáltatások</a>
            <a class="link-dark text-decoration-none" asp-page="/Contact" asp-fragment="map">Térkép</a>

            <a class="link-dark text-decoration-none" asp-page="/Spa" asp-fragment="kezelesek">Spa kezelések</a>
            <a class="link-dark text-decoration-none" asp-page="/Spa" asp-fragment="galeria">Spa galéria</a>
            <a class="link-dark text-decoration-none" asp-page="/Spa" asp-fragment="arak">Spa árak</a>

            <a class="link-dark text-decoration-none" asp-page="/Ertekelesek" asp-fragment="ertekeles">Vélemények</a>
            <a class="link-dark text-decoration-none" asp-page="/Ertekelesek" asp-fragment="kapcsolat">Kapcsolat blokk</a>
        </div>
    </div>
</div>