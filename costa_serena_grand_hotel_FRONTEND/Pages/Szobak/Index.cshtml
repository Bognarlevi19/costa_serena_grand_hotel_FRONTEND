@page
@model costa_serena_grand_hotel_FRONTEND.Pages.Szobak.IndexModel
@using costa_serena_grand_hotel_FRONTEND.Services
@inject AuthSession AuthSession
@{
    ViewData["Title"] = "Szobák";
}

<header class="position-fixed top-0 start-0 end-0 z-3 header-glass">
    <nav class="container py-2">
        <div class="row align-items-center justify-content-between header-row">
            <div class="col-4 d-flex align-items-center justify-content-start">
                <a class="btn btn-link text-dark text-decoration-none p-0 d-flex align-items-center gap-2 header-menu-btn"
                   asp-page="/Index">
                    <i class="bi bi-arrow-left"></i>
                    <span class="small text-uppercase ls mb-0">Vissza</span>
                </a>
            </div>

            <div class="col-4 d-flex align-items-center justify-content-center text-center">
                <a class="text-dark text-decoration-none fw-semibold ls hotel-brand" asp-page="/Index">
                    Costa Serena Grand Hotel
                </a>
            </div>

            <div class="col-4 d-flex align-items-center justify-content-end">
                @if (!AuthSession.IsSignedIn)
                {
                    <div class="d-flex align-items-center justify-content-end gap-2 header-actions">
                        <a class="btn btn-outline-dark btn-sm rounded-pill px-3" asp-page="/Account/Login">Bejelentkezés</a>
                        <a class="btn btn-dark btn-sm rounded-pill px-3" asp-page="/Account/Register">Regisztráció</a>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-end gap-3 header-actions">
                        <span class="small text-uppercase ls text-body-secondary mb-0 header-user-email">
                            @AuthSession.GetEmail()
                        </span>

                        <form method="post" asp-page="/Account/Logout" class="d-inline mb-0">
                            <button type="submit" class="btn btn-outline-dark btn-sm rounded-pill px-3">
                                Kijelentkezés
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </nav>
</header>

<section class="section-paper min-vh-100 pt-5">
    <div class="container py-5" style="padding-top:120px !important;">
        <div class="row mb-4">
            <div class="col-lg-8">
                <div class="small text-uppercase ls text-body-secondary mb-2">Costa Serena Grand Hotel</div>
                <h1 class="display-5 fw-semibold mb-3 text-dark">Szobakategóriák</h1>
                <p class="text-body-secondary mb-0">
                    Válassz kategóriát, és utána megjelennek az adott szobák.
                </p>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var kategoria in Model.Kategoriak)
            {
                var elsoKep = Model.GetElsoKep(kategoria.KepekJson);

                <div class="col-12 col-md-6 col-xl-3">
                    <div class="glass border border-dark border-opacity-10 rounded-4 overflow-hidden room-card h-100">
                        <div class="room-card-image d-flex align-items-center justify-content-center">
                            @if (!string.IsNullOrWhiteSpace(elsoKep))
                            {
                                <img src="@elsoKep" alt="@kategoria.Nev" class="w-100 h-100 object-fit-cover" />
                            }
                            else
                            {
                                <div class="text-center p-4 text-body-secondary">
                                    <i class="bi bi-image fs-1 d-block mb-2"></i>
                                    <span>Nincs kép megadva</span>
                                </div>
                            }
                        </div>

                        <div class="p-4">
                            <div class="small text-uppercase ls text-body-secondary mb-2">Szobakategória</div>
                            <h2 class="h4 mb-2">@kategoria.Nev</h2>
                            <p class="text-body-secondary mb-3">@kategoria.Leiras</p>

                            <div class="small text-uppercase ls text-body-secondary mb-1">Elérhető darab</div>
                            <div class="fs-5 fw-semibold mb-4">@kategoria.Darab db</div>

                            <a asp-page="/Szobak/Kategoria"
                               asp-route-id="@kategoria.Id"
                               class="btn btn-dark rounded-pill px-4">
                                Részletek
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<style>
    .room-card {
        transition: transform .2s ease, box-shadow .2s ease;
        background: rgba(255,255,255,.72);
        backdrop-filter: blur(12px);
    }

        .room-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 1rem 2rem rgba(0,0,0,.10);
        }

    .room-card-image {
        height: 260px;
        background: linear-gradient(135deg, #f3eee7 0%, #e7ded3 100%);
        border-bottom: 1px solid rgba(0,0,0,.08);
    }
</style>