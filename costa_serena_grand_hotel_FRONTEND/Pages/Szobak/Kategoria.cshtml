@page "{id:int}"
@model costa_serena_grand_hotel_FRONTEND.Pages.Szobak.KategoriaModel
@{
    ViewData["Title"] = Model.Kategoria?.Nev ?? "Kategória";
}

@if (Model.Kategoria == null)
{
    <div class="container py-5">
        <h1>A kategória nem található.</h1>
    </div>
}
else
{
    <section class="section-paper min-vh-100 pt-5">
        <div class="container py-5" style="padding-top:120px !important;">
            <div class="row mb-4">
                <div class="col-lg-8">
                    <a asp-page="/Szobak/Index" class="btn btn-outline-dark rounded-pill px-4 mb-4">Vissza</a>
                    <div class="small text-uppercase ls text-body-secondary mb-2">Szobakategória</div>
                    <h1 class="display-5 fw-semibold mb-3 text-dark">@Model.Kategoria.Nev</h1>
                    <p class="text-body-secondary mb-2">@Model.Kategoria.Leiras</p>
                    <p class="text-body-secondary mb-0"><strong>@Model.Kategoria.Darab db</strong> alapértelmezett darab</p>
                </div>
            </div>

            <div class="row g-4">
                @foreach (var szoba in Model.Szobak)
                {
                    var elsoKep = Model.GetElsoKep(szoba.KepekJson);

                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="glass border border-dark border-opacity-10 rounded-4 overflow-hidden room-card h-100">
                            <div class="room-card-image d-flex align-items-center justify-content-center">
                                @if (!string.IsNullOrWhiteSpace(elsoKep))
                                {
                                    <img src="@elsoKep" alt="@szoba.Nev" class="w-100 h-100 object-fit-cover" />
                                }
                                else
                                {
                                    <div class="text-center p-4 text-body-secondary">
                                        <i class="bi bi-image fs-1 d-block mb-2"></i>
                                        <span>Itt majd kézzel adhatsz meg szobaképet</span>
                                    </div>
                                }
                            </div>

                            <div class="p-4">
                                <h2 class="h4 mb-2">@szoba.Nev</h2>
                                <p class="text-body-secondary mb-3">@szoba.RovidLeiras</p>

                                <div class="row g-2 small text-body-secondary mb-4">
                                    <div class="col-6"><i class="bi bi-people me-2"></i>@szoba.Ferohely fő</div>
                                    <div class="col-6"><i class="bi bi-aspect-ratio me-2"></i>@szoba.Alapterulet m²</div>
                                    <div class="col-6"><i class="bi bi-building me-2"></i>@szoba.Emelet. emelet</div>
                                    <div class="col-6"><i class="bi bi-door-open me-2"></i>@szoba.Szam</div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="small text-uppercase ls text-body-secondary">Ár / éj</div>
                                        <div class="fs-4 fw-semibold">@szoba.Ar.ToString("N0") Ft</div>
                                    </div>

                                    <a asp-page="/Szobak/Details"
                                       asp-route-id="@szoba.Id"
                                       class="btn btn-dark rounded-pill px-4">
                                        Részletek
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<style>
    .room-card {
        transition: transform .2s ease, box-shadow .2s ease;
        background: rgba(255,255,255,.72);
        backdrop-filter: blur(12px);
    }

        .room-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 1rem 2rem rgba(0,0,0,.10);
        }

    .room-card-image {
        height: 260px;
        background: linear-gradient(135deg, #f3eee7 0%, #e7ded3 100%);
        border-bottom: 1px solid rgba(0,0,0,.08);
    }
</style>