@page
@model costa_serena_grand_hotel_FRONTEND.Pages.ProgramokModel
@using costa_serena_grand_hotel_FRONTEND.Services
@inject AuthSession AuthSession
@{
    ViewData["Title"] = "Programok";
}

<<header class="position-fixed top-0 start-0 end-0 z-3 header-glass">
    <nav class="container py-2">
        <div class="row align-items-center justify-content-between header-row">

            <div class="col-4 d-flex align-items-center justify-content-start">
                <button class="btn btn-link text-dark text-decoration-none p-0 d-flex align-items-center gap-2 header-menu-btn"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#menu"
                        aria-controls="menu">
                    <span class="hamburger" aria-hidden="true"></span>
                    <span class="small text-uppercase ls mb-0">Menü</span>
                </button>
            </div>

            <div class="col-4 d-flex align-items-center justify-content-center text-center">
                <a class="text-dark text-decoration-none fw-semibold ls hotel-brand" asp-page="/Index">
                    Costa Serena Grand Hotel
                </a>
            </div>

            <div class="col-4 d-flex align-items-center justify-content-end">
                @if (!AuthSession.IsSignedIn)
                {
                    <div class="d-flex align-items-center justify-content-end gap-2 header-actions">
                        <a class="btn btn-outline-dark btn-sm rounded-pill px-3" asp-page="/Account/Login">
                            Bejelentkezés
                        </a>
                        <a class="btn btn-dark btn-sm rounded-pill px-3" asp-page="/Account/Register">
                            Regisztráció
                        </a>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-end gap-3 header-actions">
                        <span class="small text-uppercase ls text-body-secondary mb-0 header-user-email">
                            @AuthSession.GetEmail()
                            @if (AuthSession.IsInRole("Admin"))
                            {
                                <span class="badge bg-danger ms-2">Admin</span>
                            }
                            else if (AuthSession.IsInRole("User"))
                            {
                                <span class="badge bg-warning ms-2">User</span>
                            }
                        </span>

                        <form method="post" asp-page="/Account/Logout" class="d-inline mb-0">
                            <button type="submit" class="btn btn-outline-dark btn-sm rounded-pill px-3">
                                Kijelentkezés
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </nav>
</header>
<!-- ===== HERO ===== -->
<section class="webshop-hero d-flex align-items-end position-relative">
    <div class="webshop-hero-media">
        <img class="webshop-hero-image" src="/kepek/webshop/webshopfokep.png" alt="Webshop - Costa Serena Grand Hotel" />
        <div class="webshop-hero-overlay"></div>
    </div>

    <div class="container position-relative pb-5">
        <div class="row">
            <div class="col-lg-9">
                <p class="small text-uppercase ls text-hero-muted mb-2">
                    Lakáskiegészítők • Illatgyertyák • Testápolás
                </p>
                <h1 class="display-5 fw-semibold mb-3 text-hero">
                    Costa Serena Webshop
                </h1>
                <p class="lead text-dark mb-0">
                    Fedezze fel a Costa Serena Grand Hotel exkluzív webshopkínálatát.
                    Válogasson elegáns lakáskiegészítők, illatgyertyák, testápolók és
                    prémium ajándékötletek közül, amelyek a hotel hangulatát idézik.
                </p>
            </div>
        </div>
    </div>
</section>


<!-- OFFCANVAS: MENU -->
<div class="offcanvas offcanvas-start bg-white text-dark" tabindex="-1" id="menu">
    <div class="offcanvas-header border-bottom border-dark border-opacity-10">
        <h5 class="offcanvas-title ls">MENÜ</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <div class="vstack gap-2">
            <a class="link-dark text-decoration-none" asp-page="/Index">Főoldal</a>
            <a class="link-dark text-decoration-none" asp-page="/Contact">Kapcsolat</a>
            <a class="link-dark text-decoration-none" asp-page="/Galeria">Galéria</a>
            <a class="link-dark text-decoration-none" asp-page="/Ertekelesek">Értékelések</a>
            <a class="link-dark text-decoration-none" asp-page="/Programok">Programok</a>
            @if (AuthSession.IsSignedIn)
            {
                <a class="link-dark text-decoration-none" asp-page="/Spa">Wellness & Spa</a>
            }
            <a class="link-dark text-decoration-none" asp-page="/Szobak/Index">Szobák megtekintése</a>
        </div>

        <hr class="my-4 opacity-25" />

        <div class="small text-uppercase ls text-body-secondary mb-2">Gyors elérés</div>
        <div class="vstack gap-2">
            <a class="link-dark text-decoration-none" asp-page="/Programok" asp-fragment="programok">Programok</a>
            <a class="link-dark text-decoration-none" asp-page="/Programok" asp-fragment="programszervezes">Programszervezés</a>
        </div>
    </div>
</div>

<!-- OFFCANVAS: RESERVE -->
<div class="offcanvas offcanvas-end bg-white text-dark" tabindex="-1" id="reserve">
    <div class="offcanvas-header border-bottom border-dark border-opacity-10">
        <h5 class="offcanvas-title ls">RESERVE</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <form class="vstack gap-3">
            <div>
                <label class="form-label small text-body-secondary">Location</label>
                <select class="form-select form-soft">
                    <option selected>All destinations</option>
                    <option>Budapest</option>
                    <option>Vienna</option>
                    <option>Prague</option>
                </select>
            </div>

            <div class="row g-2">
                <div class="col-6">
                    <label class="form-label small text-body-secondary">Arrival</label>
                    <input type="date" class="form-control form-soft" />
                </div>
                <div class="col-6">
                    <label class="form-label small text-body-secondary">Departure</label>
                    <input type="date" class="form-control form-soft" />
                </div>
            </div>

            <div class="row g-2">
                <div class="col-6">
                    <label class="form-label small text-body-secondary">Guests</label>
                    <select class="form-select form-soft">
                        <option>1</option>
                        <option selected>2</option>
                        <option>3</option>
                        <option>4</option>
                        <option>5</option>
                        <option>6</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label small text-body-secondary">Rooms</label>
                    <select class="form-select form-soft">
                        <option selected>1</option>
                        <option>2</option>
                        <option>3</option>
                        <option>4</option>
                    </select>
                </div>
            </div>

            <button type="button" class="btn btn-dark rounded-pill py-2">Search</button>
            <div class="small text-body-secondary">Itt majd összekötöd a saját foglalómotoroddal.</div>
        </form>
    </div>
</div>

<!-- ====== KÉPNAGYÍTÓ OVERLAY ====== -->
<div id="imgModal" class="img-modal" onclick="closeImage()">
    <img id="imgModalContent" alt="Nagyított kép" onclick="event.stopPropagation();" />
</div>

<!-- ===== PROGRAMOK ===== -->
<section class="py-5 section-paper">
    <div class="container py-4">

        <div id="programok" class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
            <div>
                <div class="small text-uppercase ls text-body-secondary mb-2">Ajánlott programok</div>
                <h2 class="display-6 fw-semibold mb-0">
                    Tegye még emlékezetesebbé pihenését.
                </h2>
            </div>
        </div>

        <div class="row g-4">

            <!-- Jetski -->
            <div class="col-md-6 col-lg-4 d-flex">
                <div class="glass rounded-4 overflow-hidden h-100 w-100 program-card">
                    <img src="/Kepek/programok/Gyors hajózás a trópusi vízen.png"
                         class="w-100 program-img zoom-img"
                         alt="Jetski élmény" />
                    <div class="p-4 d-flex flex-column">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Víz • Adrenalin</div>
                        <h5 class="fw-semibold mb-2">Jetski élmény</h5>
                        <p class="text-body-secondary mb-3">
                            Tapasztalja meg a sebesség és a szabadság érzését
                            biztonságos környezetben, szakértői felügyelettel.
                        </p>
                    </div>
                </div>
            </div>






        </div>

        <!-- CTA -->
        <div id="programszervezes" class="mt-5">
            <div class="glass rounded-4 p-4 p-lg-5">
                <div class="row align-items-center g-3">
                    <div class="col-lg-8">
                        <div class="small text-uppercase ls text-body-secondary mb-2">Concierge szolgáltatás</div>
                        <h3 class="fw-semibold mb-2">Segítünk a programok megszervezésében</h3>
                        <p class="text-body-secondary mb-0">
                            Kérjük, forduljon recepciónkhoz bizalommal – munkatársaink
                            örömmel segítenek a foglalásban és az időpont-egyeztetésben.
                        </p>
                    </div>
                    <div class="col-lg-4 text-lg-end">
                        <a href="/Contact" class="btn btn-dark rounded-pill px-4 py-2">
                            Érdeklődés a programokról
                        </a>
                    </div>
                </div>
            </div>
        </div>
</section>

<!-- Kep scriptek -->
<script>
    function openImage(src) {
        const modal = document.getElementById("imgModal");
        const img = document.getElementById("imgModalContent");

        img.src = src;
        modal.style.display = "flex";
        document.body.style.overflow = "hidden";
    }

    function closeImage() {
        const modal = document.getElementById("imgModal");
        const img = document.getElementById("imgModalContent");

        modal.style.display = "none";
        img.src = "";
        document.body.style.overflow = "";
    }

    document.addEventListener("DOMContentLoaded", function () {
        const images = document.querySelectorAll(".zoom-img");

        images.forEach(function (image) {
            image.style.cursor = "zoom-in";

            image.addEventListener("click", function () {
                openImage(this.src);
            });
        });
    });

    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") closeImage();
    });
</script>

